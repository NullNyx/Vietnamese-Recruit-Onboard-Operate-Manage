# ===========================================================================
# Vroom HR Frontend — Environment Variables
# ===========================================================================

# Backend API URL (FastAPI server).
# Used as the base URL for all API calls from vroom-hr/lib/api/client.ts.
# Default fallback: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# AI Studio / Gemini (legacy — will be replaced by /api/assistant in Phase 3)
# ---------------------------------------------------------------------------
# GEMINI_API_KEY: Used by the legacy AiChat component (Phase 0 left comment TODO).
# Phase 3 will replace /api/gemini with lib/api/assistant.ts calling /api/assistant.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"